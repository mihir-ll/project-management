{
    "watch": [
        "src"
    ],
    "ext": "ts,json",
    "ignore": [
        "src/**/*.spec.ts",
        "src/**/migrations/**",
        "src/**/metadata/**/*.json",
        "src/typeorm-*-datasource.ts",
        "dist",
        "node_modules"
    ],
    "delay": 2000,
    "exec": "ts-node -r tsconfig-paths/register src/main.ts"
}