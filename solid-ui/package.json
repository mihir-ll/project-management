{
  "name": "@project-management/solid-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3001",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync-themes": "copyfiles -u 5 \"node_modules/@solidxai/core-ui/dist/resources/themes/**/*\" public",
    "postinstall": "npm run sync-themes",
    "solidx:dev": "npm run dev"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.7",
    "@solidxai/core-ui": "^0.1.13-beta.0",
    "axios": "^1.13.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "^8.1.2",
    "react-router-dom": "^7.13.0",
    "sass": "^1.97.3"
  },
  "overrides": {
    "@codemirror/lint": "6.9.5",
    "@codemirror/view": "6.43.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.59.1",
    "vite": "^7.2.4"
  }
}
